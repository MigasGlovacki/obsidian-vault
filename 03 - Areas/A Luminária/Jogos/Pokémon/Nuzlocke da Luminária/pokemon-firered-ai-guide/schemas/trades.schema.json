{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "receive_species_id",
      "requested_species_id",
      "availability",
      "source"
    ],
    "properties": {
      "id": {
        "type": "string"
      },
      "availability": {
        "enum": [
          "event_required",
          "normal",
          "optional",
          "trade_required",
          "unavailable_normally",
          "version_specific"
        ]
      },
      "source": {
        "type": "object",
        "required": [
          "repository",
          "commit",
          "path"
        ],
        "properties": {
          "repository": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "line": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      },
      "receive_species_id": {
        "type": "string"
      },
      "requested_species_id": {
        "type": "string"
      }
    }
  }
}
